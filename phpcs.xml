<?xml version="1.0"?>
<ruleset name="joeriabbo">

    <file>app</file>
    <file>tests</file>

    <rule ref="PSR1" />
    <rule ref="PSR2" />
    <rule ref="PSR12" />

    <rule ref="Generic.Files.LineLength">
        <severity>0</severity>
    </rule>

    <!-- Test methods use snake_case by Laravel convention -->
    <rule ref="PSR1.Methods.CamelCapsMethodName">
        <exclude-pattern>tests/</exclude-pattern>
    </rule>

</ruleset>
